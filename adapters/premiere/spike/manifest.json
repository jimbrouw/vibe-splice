{
  "id": "com.vibesplice.m0spike",
  "name": "M0 Timeline-Write Spike",
  "version": "0.1.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "premierepro",
    "minVersion": "25.0"
  },
  "requiredPermissions": {
    "localFileSystem": "request"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "m0spike",
      "label": { "default": "M0 Spike" },
      "minimumSize": { "width": 320, "height": 400 },
      "maximumSize": { "width": 1200, "height": 2000 },
      "preferredDockedSize": { "width": 420, "height": 700 },
      "preferredFloatingSize": { "width": 420, "height": 700 }
    }
  ]
}
